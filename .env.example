# Get a free API key at https://getsongbpm.com/api
# Copy this file to .env and paste your key below, then restart the dev server.
EXPO_PUBLIC_GETSONGBPM_API_KEY=paste_your_key_here

# Optional: shared library sync (see SYNC.md). Leave blank for a local-only,
# single-device library. To enable, create a free Supabase project, run the SQL
# in SYNC.md, and paste your Project URL + anon (public) key below.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
